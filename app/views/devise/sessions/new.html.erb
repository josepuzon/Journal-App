<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="mb-4">Log in</h2>

      <%= form_with scope: :user, url: session_path(:user), local: true do |form| %>
        <div class="mb-3">
          <%= form.label :email, class: "form-label" %>
          <%= form.email_field :email, autofocus: true, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :password, class: "form-label" %>
          <%= form.password_field :password, autocomplete: "current-password", class: "form-control" %>
        </div>

        <div class="mb-3 form-check">
          <%= form.check_box :remember_me, class: "form-check-input" %>
          <%= form.label :remember_me, class: "form-check-label" %>
        </div>

        <%= form.submit "Log in", class: "btn btn-primary" %>
      <% end %>

      <hr>

      <%= link_to "Sign up", new_user_registration_path, class: "btn btn-link" %><br>
      <%= link_to "Forgot your password?", new_user_password_path, class: "btn btn-link" %>
    </div>
  </div>
</div>
