<div class="container mt-4">
  <h2 class="mb-4">📅 Tasks for Today</h2>

  <% if @tasks.any? %>
    <div class="row row-cols-1 row-cols-md-2 g-4">
      <% @tasks.each do |task| %>
        <div class="col">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h5 class="card-title"><%= task.title %></h5>
              <p class="card-text mb-1"><strong>Category:</strong> <%= task.category.name %></p>
              <p class="card-text mb-0"><strong>Due:</strong> <%= task.due_date || "No due date" %></p>
            </div>
            <div class="card-footer text-end">
              <%= link_to "View", category_task_path(task.category, task), class: "btn btn-sm btn-outline-primary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info mt-3">No tasks for today.</div>
  <% end %>

  <hr class="my-5">

  <h4 class="mb-3">➕ Add Tasks to your Categories</h4>
  <div class="list-group">
    <% current_user.categories.each do |category| %>
      <%= link_to "#{category.name}", new_category_task_path(category), class: "list-group-item list-group-item-action" %>
    <% end %>
  </div>

  <hr class="mt-5">

  <%= link_to "⬅ Back to Categories", categories_path, class: "btn btn-outline-secondary mt-3" %>
</div>
