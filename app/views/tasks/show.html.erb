<br>
<div class="container mt-4 position-relative">
  <div class="position-absolute" style="top: -1.5rem; left: 0;">
    <h1 class="fw-semibold">Task:</h1>
  </div>

  <br>
  <br>

  <div class="card shadow-sm">
    <div class="card-header">
      <h4 class="mb-0"><%= @task.title %></h4>
    </div>
    <div class="card-body">
      <% if @task.note.present? %>
        <p><strong>Note:</strong> <%= @task.note %></p>
      <% end %>

      <p><strong>Due Date:</strong> <%= @task.due_date || "No due date" %></p>
      <p><strong>Category:</strong> <%= @task.category.name %></p>
    </div>
    <div class="card-footer d-flex justify-content-between">
      <div>
        <%= link_to "✏️ Edit", edit_category_task_path(@task.category, @task), class: "btn btn-outline-secondary btn-sm" %>
        <%= link_to "🗑️ Delete", category_task_path(@task.category, @task),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "btn btn-outline-danger btn-sm" %>
      </div>
      <%= link_to "⬅ Back to Category", category_path(@task.category), class: "btn btn-sm btn-outline-primary" %>
    </div>
  </div>
</div>
