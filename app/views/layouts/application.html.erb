<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Journal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- ✅ Navbar added here -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light px-3 mb-4">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">📖 Journal App</a>

        <% if user_signed_in? %>
          <div class="collapse navbar-collapse justify-content-end">
            <!-- Left-aligned links -->
            <ul class="navbar-nav">
              <li class="nav-item">
                <%= link_to "📂 Categories", categories_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "📅 Today's Tasks", tasks_today_path, class: "nav-link" %>
              </li>
            </ul>

            <!-- Right-aligned Log out -->
            <ul class="navbar-nav">
              <li class="nav-item">
                <%= link_to "Log out", destroy_user_session_path,
                        data: { turbo_method: :delete },
                        class: "nav-link text-danger" %>
              </li>
            </ul>
          </div>
        <% else %>
          <div class="collapse navbar-collapse justify-content-end">
            <ul class="navbar-nav">
              <li class="nav-item">
                <%= link_to "Log in", new_user_session_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Sign up", new_user_registration_path, class: "nav-link" %>
              </li>
            </ul>
          </div>
        <% end %>
      </div>
    </nav>


    <% if notice %>
      <p class="alert alert-success"><%= notice %></p>
    <% end %>

    <% if alert %>
      <p class="alert alert-danger"><%= alert %></p>
    <% end %>

    <%= yield %>
  </body>
</html>
