<div class="container mt-4">
  <div class="card shadow-sm">
    <div class="card-header">
      <h4 class="mb-0"><%= @category.new_record? ? "New Category" : "Edit Category" %></h4>
    </div>
    <div class="card-body">
      <%= form_with(model: @category, local: true) do |form| %>
        <% if @category.errors.any? %>
          <div class="alert alert-danger">
            <h5><%= pluralize(@category.errors.count, "error") %> below:</h5>
            <ul>
              <% @category.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= form.label :name, class: "form-label" %>
          <%= form.text_field :name, class: "form-control", autofocus: true %>
        </div>

        <div class="mb-3">
          <%= form.label :description, class: "form-label" %>
          <%= form.text_area :description, class: "form-control", rows: 3 %>
        </div>

        <%= form.submit "Save Category", class: "btn btn-primary" %>
        <%= link_to "Cancel", categories_path, class: "btn btn-outline-secondary ms-2" %>
      <% end %>
    </div>
  </div>
</div>
